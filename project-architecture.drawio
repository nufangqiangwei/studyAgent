          <mxGeometry height="410" width="600" x="140" y="310" as="geometry" />
        </mxCell>
        <mxCell id="task_runtime" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#3b82f6;fontSize=12;align=left;spacing=10;" value="TaskRuntime 包装对象&lt;br&gt;&lt;br&gt;职责备注：单个 task 的轻量句柄，限制 task_id / agent_name 范围。&lt;br&gt;&lt;br&gt;方法：&lt;br&gt;Start(ctx, TaskStart)&lt;br&gt;StartInput(ctx, string)&lt;br&gt;Publish / PublishAsync&lt;br&gt;State()&lt;br&gt;AgentSnapshot()&lt;br&gt;Cancel()" vertex="1">
          <mxGeometry height="190" width="600" x="140" y="760" as="geometry" />
        </mxCell>
        <mxCell id="bus" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;fontStyle=1;align=left;spacing=10;" value="eventbus.Bus&lt;br&gt;&lt;br&gt;职责备注：事件发布、订阅、过滤和异步队列；runtime 内部所有状态推进都通过 Event 进入。&lt;br&gt;&lt;br&gt;核心接口：&lt;br&gt;Subscribe(Filter, Handler)&lt;br&gt;SubscribeReadOnly(Filter, Handler)&lt;br&gt;Publish(ctx, Event)&lt;br&gt;PublishAsync(ctx, Event)&lt;br&gt;Broadcast / Enqueue&lt;br&gt;Close" vertex="1">
          <mxGeometry height="370" width="520" x="940" y="310" as="geometry" />
        </mxCell>
        <mxCell id="event" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#16a34a;fontSize=12;align=left;spacing=10;" value="eventbus.Event&lt;br&gt;&lt;br&gt;字段：&lt;br&gt;ID, Topic, Type, TaskID&lt;br&gt;Source, Payload, Metadata&lt;br&gt;OccurredAt&lt;br&gt;&lt;br&gt;Filter.Match(event) 用于路由订阅。" vertex="1">
          <mxGeometry height="210" width="520" x="940" y="730" as="geometry" />
        </mxCell>
        <mxCell id="reactor" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#bbf7d0;strokeColor=#16a34a;fontSize=12;fontStyle=1;align=left;spacing=10;" value="reactor.Reactor&lt;br&gt;&lt;br&gt;职责备注：事件驱动推进器；接收事件后解析 TaskRuntime，调用状态机，发布派生事件，并分发 effects。&lt;br&gt;&lt;br&gt;核心方法：&lt;br&gt;Attach(bus, filter)&lt;br&gt;HandleEvent(ctx, Event)&lt;br&gt;Advance(ctx, Event)&lt;br&gt;CancelTask(taskID)&lt;br&gt;EffectStarted / Succeeded / Failed&lt;br&gt;EffectResultEvents" vertex="1">
          <mxGeometry height="370" width="520" x="1540" y="310" as="geometry" />
        </mxCell>
        <mxCell id="reactor_ifaces" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#16a34a;fontSize=11;align=left;spacing=10;" value="reactor 关键接口&lt;br&gt;&lt;br&gt;StateMachine.HandleEvent(ctx, Event) StateResult&lt;br&gt;RuntimeResolver.ResolveRuntime(ctx, Event) TaskRuntime&lt;br&gt;EffectDispatcher.DispatchEffect(ctx, EffectDispatchRequest)&lt;br&gt;EffectExecutor.ExecuteEffect(ctx, TaskRuntime, Effect) EffectResult" vertex="1">
          <mxGeometry height="210" width="520" x="1540" y="730" as="geometry" />
        </mxCell>
        <mxCell id="statemachine" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dcfce7;strokeColor=#15803d;fontSize=12;fontStyle=1;align=left;spacing=10;" value="statemachine.TaskStateMachine&lt;br&gt;&lt;br&gt;职责备注：可恢复任务状态机；根据事件迁移 TaskState，记录 pending model/tool/user/sub-agent，输出 reactor.Effect。&lt;br&gt;&lt;br&gt;实现接口：&lt;br&gt;reactor.StateMachine&lt;br&gt;&lt;br&gt;核心方法：&lt;br&gt;HandleEvent(ctx, Event) StateResult&lt;br&gt;State(ctx, taskID)" vertex="1">
          <mxGeometry height="350" width="520" x="2260" y="310" as="geometry" />
        </mxCell>
        <mxCell id="state" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#15803d;fontSize=11;align=left;spacing=10;" value="TaskState&lt;br&gt;&lt;br&gt;Phase：Created / Running / WaitingModel / WaitingTool / WaitingUserInput / WaitingSubAgent / Completed / Failed / Cancelled&lt;br&gt;&lt;br&gt;含 pending 调用、失败计数、结果、生命周期记录。" vertex="1">
          <mxGeometry height="240" width="520" x="2260" y="700" as="geometry" />
        </mxCell>
        <mxCell id="agent_flow" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#15803d;fontSize=11;align=left;spacing=10;" value="AgentFlowRegistry / AgentFlowMachine&lt;br&gt;&lt;br&gt;职责备注：可配置 agent 内部业务阶段迁移。&lt;br&gt;&lt;br&gt;接口：&lt;br&gt;InitialPhase() AgentPhase&lt;br&gt;HandleAgentEvent(ctx, TaskState, Event) AgentFlowResult" vertex="1">
          <mxGeometry height="340" width="200" x="2820" y="460" as="geometry" />
        </mxCell>
        <mxCell id="storage" parent="1" style="shape=cylinder3d;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#ffedd5;strokeColor=#c2410c;fontSize=12;fontStyle=1;align=left;spacing=10;" value="persistence.RuntimeStorage&lt;br&gt;&lt;br&gt;职责备注：runtime 可恢复事实来源，统一暴露四类 store。&lt;br&gt;&lt;br&gt;接口：&lt;br&gt;TaskStates()&lt;br&gt;AgentSnapshots()&lt;br&gt;Runtimes()&lt;br&gt;Events()&lt;br&gt;Backend()&lt;br&gt;Close()" vertex="1">
          <mxGeometry height="340" width="460" x="3180" y="300" as="geometry" />
        </mxCell>
        <mxCell id="stores" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#c2410c;fontSize=11;align=left;spacing=10;" value="Store 接口&lt;br&gt;&lt;br&gt;TaskStateStore：Load / Save / List&lt;br&gt;SnapshotStore：Load / Save / List&lt;br&gt;RuntimeStore：Load / Save / Delete / List&lt;br&gt;EventStore：Append / List / Last&lt;br&gt;&lt;br&gt;实现：file_store / sqlite_store / mirror" vertex="1">
          <mxGeometry height="260" width="660" x="3180" y="680" as="geometry" />
        </mxCell>
        <mxCell id="registry_runtime" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;fontSize=11;align=left;spacing=10;" value="RuntimeRegistry&lt;br&gt;&lt;br&gt;职责备注：按 task_id 查找 reactor.TaskRuntime。&lt;br&gt;实现 RuntimeResolver。&lt;br&gt;&lt;br&gt;方法：Register / Unregister / ResolveRuntime / List" vertex="1">
          <mxGeometry height="240" width="460" x="160" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="registry_executor" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;fontSize=11;align=left;spacing=10;" value="ExecutorRegistry&lt;br&gt;&lt;br&gt;职责备注：按 EffectType 查找执行器。&lt;br&gt;&lt;br&gt;方法：Register / RegisterFunc / Lookup / ListTypes&lt;br&gt;&lt;br&gt;常见 effect：agent_start、agent_resume、model_call、tool_dispatch、task.completed.emit" vertex="1">
          <mxGeometry height="280" width="460" x="160" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="dispatcher_async" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;fontSize=11;align=left;spacing=10;" value="AsyncEffectDispatcher&lt;br&gt;&lt;br&gt;职责备注：异步执行 effect，使用 semaphore 控制并发，回调 reporter 记录 effect 生命周期。" vertex="1">
          <mxGeometry height="240" width="460" x="700" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="dispatcher_sync" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;fontSize=11;align=left;spacing=10;" value="SyncEffectDispatcher&lt;br&gt;&lt;br&gt;职责备注：测试 / 同步包装可用的同步分发器；同样实现 EffectDispatcher。" vertex="1">
          <mxGeometry height="240" width="460" x="700" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="task_agent_exec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;fontStyle=1;align=left;spacing=10;" value="taskAgentExecutor&lt;br&gt;&lt;br&gt;职责备注：runtime 内部默认执行器；把 EffectAgentStart / EffectAgentResume 转成 Agent.Start / Agent.Resume。&lt;br&gt;&lt;br&gt;依赖：taskAgentRegistry" vertex="1">
          <mxGeometry height="260" width="480" x="1240" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="agents_pkg" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;fontSize=11;align=left;spacing=10;" value="runtime/agents&lt;br&gt;&lt;br&gt;Agent 接口：&lt;br&gt;Name() string&lt;br&gt;Start(ctx, AgentStartInput) AgentResult&lt;br&gt;Resume(ctx, AgentResumeInput) AgentResult&lt;br&gt;Snapshot(ctx, taskID) AgentSnapshot&lt;br&gt;&lt;br&gt;数据：AgentSnapshot、Message、ToolSpec、Decision" vertex="1">
          <mxGeometry height="300" width="480" x="1240" y="1500" as="geometry" />
        </mxCell>
        <mxCell id="builtin_agents" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;fontSize=11;align=left;spacing=10;" value="builtinagents&lt;br&gt;&lt;br&gt;职责备注：内置 agent 实现。当前包含 default、analyze、tool-tester、task-intake；内部 agentRuntime 负责把模型决策翻译为 runtime 事件。" vertex="1">
          <mxGeometry height="300" width="480" x="1800" y="1500" as="geometry" />
        </mxCell>
        <mxCell id="model_exec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;fontStyle=1;align=left;spacing=10;" value="contextmgr.ModelExecutor&lt;br&gt;&lt;br&gt;职责备注：执行 EffectModelCall；解码 ModelCallPayload，调用 Manager，生成 model.response_received / failed 事件。&lt;br&gt;&lt;br&gt;实现：reactor.EffectExecutor" vertex="1">
          <mxGeometry height="260" width="480" x="1800" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="ctx_manager" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;fontSize=11;align=left;spacing=10;" value="contextmgr.Manager&lt;br&gt;&lt;br&gt;职责备注：构造 llmClient.Request，调用模型，规范化 tool call ID 和空参数，生成 assistant/tool message。&lt;br&gt;&lt;br&gt;接口：LLMClient.Complete(ctx, Request) Response" vertex="1">
          <mxGeometry height="260" width="480" x="2360" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="tool_adapter" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;fontStyle=1;align=left;spacing=10;" value="runtime/tools.Adapter&lt;br&gt;&lt;br&gt;职责备注：执行 EffectToolDispatch；调用 capability/tool.Manage，生成 tool.completed / tool.failed 事件。&lt;br&gt;&lt;br&gt;方法：Specs() / ToolNames() / ExecuteEffect(...)" vertex="1">
          <mxGeometry height="280" width="480" x="2360" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="terminal_exec" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;fontStyle=1;align=left;spacing=10;" value="terminalEffectExecutor&lt;br&gt;&lt;br&gt;职责备注：把状态机终态 effect 转成 task.result topic 事件。&lt;br&gt;&lt;br&gt;输入：task.completed.emit / task.failed.emit / task.cancelled.emit&lt;br&gt;输出：task.completed / task.failed / task.cancelled" vertex="1">
          <mxGeometry height="280" width="480" x="2920" y="1180" as="geometry" />
        </mxCell>
        <mxCell id="event_recorder" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#64748b;fontSize=11;align=left;spacing=10;" value="persistence.EventRecorder&lt;br&gt;&lt;br&gt;职责备注：read-only 订阅 eventbus，把运行时事件追加到 EventStore。&lt;br&gt;&lt;br&gt;接口：HandleEvent(ctx, Event)" vertex="1">
          <mxGeometry height="240" width="480" x="2920" y="1540" as="geometry" />
        </mxCell>
        <mxCell id="ext_llm" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;align=left;spacing=10;" value="foundation/llmClient&lt;br&gt;&lt;br&gt;外部边界：具体 provider HTTP 适配，不属于 runtime 核心。contextmgr 只依赖 LLMClient 接口。" vertex="1">
          <mxGeometry height="220" width="600" x="280" y="2140" as="geometry" />
        </mxCell>
        <mxCell id="ext_tool" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;align=left;spacing=10;" value="capability/tool&lt;br&gt;&lt;br&gt;外部边界：工具注册表、policy 托管执行、内置 workspace / ask_user 等工具。runtime/tools.Adapter 只做事件适配。" vertex="1">
          <mxGeometry height="220" width="600" x="1120" y="2140" as="geometry" />
        </mxCell>
        <mxCell id="ext_content" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;align=left;spacing=10;" value="content.Env&lt;br&gt;&lt;br&gt;外部边界：为工具执行提供单次运行 IO、workdir、配置、日志和命令/agent 句柄。" vertex="1">
          <mxGeometry height="220" width="600" x="1960" y="2140" as="geometry" />
        </mxCell>
        <mxCell id="ext_policy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=12;align=left;spacing=10;" value="foundation/policy&lt;br&gt;&lt;br&gt;外部边界：read / validate / modify 权限判断。由 capability/tool.Manage 使用，runtime 不直接写策略逻辑。" vertex="1">
          <mxGeometry height="220" width="600" x="2800" y="2140" as="geometry" />
        </mxCell>
        <mxCell id="legend_events" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#8b5cf6;fontSize=12;align=left;spacing=10;" value="主要 EventType：&lt;br&gt;task.start_requested -&gt; agent.model_requested -&gt; model.response_received / failed -&gt; agent.tool_requested -&gt; tool.completed / failed -&gt; agent.completed / failed&lt;br&gt;&lt;br&gt;等待类事件：agent.user_input_requested / user_input.received，agent.sub_agent_requested / sub_agent.completed / failed" vertex="1">
          <mxGeometry height="150" width="1720" x="160" y="2700" as="geometry" />
        </mxCell>
        <mxCell id="legend_effects" parent="1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#ffffff;strokeColor=#8b5cf6;fontSize=12;align=left;spacing=10;" value="主要 EffectType：&lt;br&gt;agent_start、agent_resume、model_call、tool_dispatch、user_input_request、sub_agent_dispatch、task.completed.emit、task.failed.emit、task.cancelled.emit&lt;br&gt;&lt;br&gt;规则：状态机只产出 effect；具体副作用由 ExecutorRegistry 找到执行器完成。" vertex="1">
          <mxGeometry height="150" width="1720" x="2040" y="2700" as="geometry" />
        </mxCell>
